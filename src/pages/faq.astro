---
import BaseLayout from "../layouts/BaseLayout.astro";
import { FAQ_SECTIONS } from "../data/faq";
import { breadcrumbJsonLd } from "../data/structured-data";
import { pagePath } from "../data/site";

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: FAQ_SECTIONS.flatMap((section) =>
    section.entries.map((entry) => ({
      "@type": "Question",
      name: entry.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: entry.answer,
      },
    })),
  ),
};

const jsonLd = [
  faqJsonLd,
  breadcrumbJsonLd([
    { name: "Home", path: "/" },
    { name: "FAQ", path: "/faq" },
  ]),
];
---

<BaseLayout
  meta={{
    title: "FAQ",
    description:
      "Breachwalker FAQ — extraction survival, Bitcoin rifts, pay to win policy, free-to-play economy, player marketplace, earning through items, and NFT bridge on Base.",
    path: "/faq",
    ogImageAlt: "Breachwalker FAQ — extraction survival, marketplace, NFT bridge",
  }}
  jsonLd={jsonLd}
>
  <header class="page-header">
    <div class="container container--narrow">
      <nav class="breadcrumb muted" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true"> / </span>
        <span>FAQ</span>
      </nav>
      <p class="eyebrow">Support</p>
      <h1>Frequently asked questions</h1>
      <p class="muted">
        Straight answers on breaching, the closed alpha, item economy,
        free-to-play play, pay-to-win design, and the NFT bridge on Base.
      </p>
    </div>
  </header>

  <div class="container container--narrow faq-page">
    <nav class="faq-nav muted" aria-label="FAQ sections">
      {
        FAQ_SECTIONS.map((section) => (
          <a href={`#faq-${section.id}`}>{section.title}</a>
        ))
      }
    </nav>
    {
      FAQ_SECTIONS.map((section) => (
        <section class="faq-section" aria-labelledby={`faq-${section.id}`}>
          <h2 id={`faq-${section.id}`} class="faq-section__title">
            {section.title}
          </h2>
          {section.intro && (
            <p class="faq-section__intro muted">{section.intro}</p>
          )}
          <div class="faq-list">
            {section.entries.map((entry) => (
              <details class="faq-item">
                <summary>{entry.question}</summary>
                <div class="faq-answer">
                  <p>{entry.answer}</p>
                </div>
              </details>
            ))}
          </div>
        </section>
      ))
    }
    <p class="faq-cta">
      <a class="btn btn--primary" href={pagePath("/alpha")} data-analytics="cta-alpha">
        Request alpha access
      </a>
      <a class="btn btn--ghost" href={pagePath("/how-it-works")}>
        How it works
      </a>
      <a class="btn btn--ghost" href={pagePath("/item-economy")}>
        Item economy
      </a>
    </p>
  </div>
</BaseLayout>

<style>
  .faq-page {
    padding-bottom: var(--space-4xl);
  }

  .faq-nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm) var(--space-md);
    margin-bottom: var(--space-2xl);
    font-size: 0.875rem;
  }

  .faq-nav a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .faq-nav a:hover {
    color: var(--color-accent);
  }

  .breadcrumb {
    font-size: 0.8125rem;
    margin-bottom: var(--space-md);
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--color-text);
  }

  .faq-section {
    margin-bottom: var(--space-2xl);
  }

  .faq-section__title {
    font-size: 1.125rem;
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 var(--space-md);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .faq-section__intro {
    margin: 0 0 var(--space-lg);
    font-size: 0.9375rem;
    line-height: 1.65;
  }

  .faq-section .faq-list {
    padding: 0;
  }

  .faq-cta {
    margin-top: var(--space-xl);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }
</style>
