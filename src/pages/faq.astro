---
import BaseLayout from "../layouts/BaseLayout.astro";
import { FAQ_ENTRIES } from "../data/faq";
---

<BaseLayout
  meta={{
    title: "FAQ",
    description:
      "Frequently asked questions about Breachwalker — breaches, territories, Strikes, and the closed alpha.",
    path: "/faq",
  }}
>
  <header class="page-header">
    <div class="container container--narrow">
      <p class="eyebrow">Support</p>
      <h1>Frequently asked questions</h1>
      <p class="muted">
        Answers about the breach loop, alpha access, and what Breachwalker is
        (and is not).
      </p>
    </div>
  </header>

  <div class="container container--narrow faq-list">
    {
      FAQ_ENTRIES.map((entry) => (
        <details class="faq-item">
          <summary>{entry.question}</summary>
          <div class="faq-answer">
            <p>{entry.answer}</p>
          </div>
        </details>
      ))
    }
    <p style="margin-top: 2rem;">
      <a class="btn btn--primary" href="/alpha" data-analytics="cta-alpha">
        Request alpha access
      </a>
    </p>
  </div>
</BaseLayout>
