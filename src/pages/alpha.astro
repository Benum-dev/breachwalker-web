---
import BaseLayout from "../layouts/BaseLayout.astro";
import AlphaSignup from "../components/AlphaSignup.astro";
import { COPY } from "../data/copy";
import { SITE, pagePath } from "../data/site";
import { breadcrumbJsonLd, webPageJsonLd } from "../data/structured-data";

const jsonLd = [
  webPageJsonLd({
    name: "Alpha access",
    description:
      "Request closed alpha access to Breachwalker — block-derived expedition survival.",
    path: "/alpha",
  }),
  breadcrumbJsonLd([
    { name: "Home", path: "/" },
    { name: "Alpha access", path: "/alpha" },
  ]),
];
---

<BaseLayout
  meta={{
    title: "Alpha access",
    description:
      "Request closed alpha access to Breachwalker — block-derived expedition survival.",
    path: "/alpha",
    ogImageAlt: "Request Breachwalker closed alpha access",
  }}
  jsonLd={jsonLd}
>
  <header class="page-header">
    <div class="container container--narrow">
      <nav class="breadcrumb muted" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true"> / </span>
        <span>Alpha access</span>
      </nav>
      <p class="eyebrow">Closed alpha</p>
      <h1>{COPY.alpha.title}</h1>
      <p class="muted">{COPY.alpha.intro}</p>
    </div>
  </header>

  <section class="container container--narrow" style="padding-bottom: 4.5rem;">
    <AlphaSignup />
    <div class="discord-callout">
      <p class="muted">
        Want announcements and build drops in one place?
        <a href={SITE.discordInviteUrl} target="_blank" rel="noopener noreferrer">Join the Discord</a>.
      </p>
    </div>
    <p class="muted" style="margin-top: 1.5rem; font-size: 0.875rem;">
      By signing up you agree to our <a href={pagePath("/privacy")}>Privacy Policy</a> and
      <a href={pagePath("/terms")}>Terms of Service</a>.
    </p>
  </section>
</BaseLayout>

<style>
  .breadcrumb {
    font-size: 0.8125rem;
    margin-bottom: var(--space-md);
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--color-text);
  }

  .discord-callout {
    margin-top: var(--space-lg);
    padding: var(--space-md) var(--space-lg);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    background: var(--color-bg-elevated);
  }

  .discord-callout a {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
  }

  .discord-callout a:hover {
    color: var(--color-accent-hover);
  }
</style>

<script is:inline define:vars={{ contactEmail: SITE.contactEmail }}>
  const emailField = document.querySelector('input[type="email"]');
  emailField?.addEventListener("focus", () => {
    window.dispatchEvent(
      new CustomEvent("bw:analytics", { detail: "alpha_signup_start" }),
    );
  });
</script>
