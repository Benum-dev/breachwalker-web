---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../data/site";
---

<BaseLayout
  meta={{
    title: "Terms of Service",
    description: "Terms of service for the Breachwalker website and closed alpha.",
    path: "/terms",
  }}
>
  <header class="page-header">
    <div class="container container--narrow">
      <p class="eyebrow">Legal</p>
      <h1>Terms of Service</h1>
      <p class="muted">Last updated: {SITE.legalUpdated}</p>
    </div>
  </header>

  <article class="container container--narrow prose">
    <p>
      These terms govern your use of <a href={SITE.url}>breachwalker.com</a> and
      participation in Breachwalker, a production of{" "}
      <a href={SITE.producer.url}>{SITE.producer.name}</a>. By using the site or
      signing up for alpha access, you agree to these terms.
    </p>

    <h2>Pre-release software</h2>
    <p>
      Breachwalker is in active development. Alpha builds may change, break, or
      wipe progress without notice. Features described on the marketing site may
      not yet be available in the client.
    </p>

    <h2>Alpha access</h2>
    <p>
      Alpha access is invite-only and may be revoked at any time. Signing up for
      the waitlist does not guarantee access or a specific timeline.
    </p>

    <h2>Acceptable use</h2>
    <ul>
      <li>Do not attempt to disrupt the site, scrape signup data, or abuse forms.</li>
      <li>Do not use the alpha to harass other testers or staff.</li>
      <li>Do not reverse-engineer or redistribute alpha builds without permission.</li>
    </ul>

    <h2>Intellectual property</h2>
    <p>
      Breachwalker, its name, art, and code are owned by {SITE.producer.name}.
      You may not copy or commercialize project assets without written consent.
    </p>

    <h2>Disclaimer</h2>
    <p>
      The site and alpha are provided “as is” without warranties of any kind. We
      are not liable for indirect or consequential damages arising from your use
      of the site or alpha software.
    </p>

    <h2>Age</h2>
    <p>You must be at least 13 years old to use the site or sign up for alpha access.</p>

    <h2>Privacy</h2>
    <p>
      Our collection of personal data is described in the
      <a href="/privacy">Privacy Policy</a>.
    </p>

    <h2>Changes</h2>
    <p>
      We may update these terms. Continued use after changes constitutes
      acceptance of the updated terms.
    </p>

    <h2>Contact</h2>
    <p>
      Questions: <a href={`mailto:${SITE.contactEmail}`}>{SITE.contactEmail}</a>
    </p>
  </article>
</BaseLayout>
