---
import BaseLayout from "../layouts/BaseLayout.astro";
import type { SeoPage } from "../data/seo-pages";
import {
  breadcrumbJsonLd,
  webPageJsonLd,
} from "../data/structured-data";
import { pagePath } from "../data/site";

interface Props {
  page: SeoPage;
}

const { page } = Astro.props;

const defaultRelated = [
  { href: pagePath("/how-it-works"), label: "How it works" },
  { href: pagePath("/bitcoin-rifts"), label: "Bitcoin rifts" },
  { href: pagePath("/item-economy"), label: "Item economy" },
  { href: pagePath("/alpha"), label: "Alpha access" },
];

const related = (page.relatedLinks ?? defaultRelated).map((link) => ({
  ...link,
  href: pagePath(link.href),
}));

const jsonLd = [
  webPageJsonLd({
    name: page.title,
    description: page.metaDescription,
    path: page.path,
  }),
  breadcrumbJsonLd([
    { name: "Home", path: "/" },
    { name: page.title, path: page.path },
  ]),
];
---

<BaseLayout
  meta={{
    title: page.metaTitle,
    description: page.metaDescription,
    path: page.path,
    ogImageAlt: `${page.metaTitle} — Breachwalker`,
  }}
  jsonLd={jsonLd}
>
  <header class="page-header">
    <div class="container container--narrow">
      <nav class="breadcrumb muted" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true"> / </span>
        <span>{page.title}</span>
      </nav>
      <p class="eyebrow">{page.eyebrow}</p>
      <h1>{page.title}</h1>
      <p class="muted lead">{page.intro}</p>
    </div>
  </header>

  <article class="container container--narrow prose seo-page">
    {
      page.sections.map((section) => (
        <section>
          <h2>{section.title}</h2>
          {section.paragraphs.map((p) => (
            <p>{p}</p>
          ))}
          {section.bullets && (
            <ul>
              {section.bullets.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          )}
        </section>
      ))
    }
    <p class="seo-page__cta">
      <a class="btn btn--primary" href={pagePath("/alpha")} data-analytics="cta-alpha">
        {page.ctaLabel ?? "Request alpha access"}
      </a>
      <a class="btn btn--ghost" href={pagePath("/faq")}>Read FAQ</a>
    </p>
    <nav class="seo-related muted" aria-label="Related pages">
      <span>Related:</span>
      {related.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>
  </article>
</BaseLayout>

<style>
  .breadcrumb {
    font-size: 0.8125rem;
    margin-bottom: var(--space-md);
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--color-text);
  }

  .lead {
    font-size: 1.125rem;
    line-height: 1.65;
  }

  .seo-page__cta {
    margin-top: var(--space-2xl);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .seo-related {
    margin-top: var(--space-xl);
    font-size: 0.875rem;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm) var(--space-md);
    align-items: center;
  }

  .seo-related a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .seo-related a:hover {
    color: var(--color-text);
  }
</style>
