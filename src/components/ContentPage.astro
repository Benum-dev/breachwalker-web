---
import BaseLayout from "../layouts/BaseLayout.astro";
import type { SeoPage } from "../data/seo-pages";

interface Props {
  page: SeoPage;
}

const { page } = Astro.props;
---

<BaseLayout
  meta={{
    title: page.metaTitle,
    description: page.metaDescription,
    path: page.path,
  }}
>
  <header class="page-header">
    <div class="container container--narrow">
      <p class="eyebrow">{page.eyebrow}</p>
      <h1>{page.title}</h1>
      <p class="muted lead">{page.intro}</p>
    </div>
  </header>

  <article class="container container--narrow prose seo-page">
    {
      page.sections.map((section) => (
        <section>
          <h2>{section.title}</h2>
          {section.paragraphs.map((p) => (
            <p>{p}</p>
          ))}
          {section.bullets && (
            <ul>
              {section.bullets.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          )}
        </section>
      ))
    }
    <p class="seo-page__cta">
      <a class="btn btn--primary" href="/alpha" data-analytics="cta-alpha">
        {page.ctaLabel ?? "Request alpha access"}
      </a>
      <a class="btn btn--ghost" href="/faq">Read FAQ</a>
    </p>
    <nav class="seo-related muted" aria-label="Related pages">
      <span>Related:</span>
      <a href="/how-it-works">How it works</a>
      <a href="/bitcoin-rifts">Bitcoin rifts</a>
      <a href="/item-economy">Item economy</a>
      <a href="/alpha">Alpha access</a>
    </nav>
  </article>
</BaseLayout>

<style>
  .lead {
    font-size: 1.125rem;
    line-height: 1.65;
  }

  .seo-page__cta {
    margin-top: var(--space-2xl);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .seo-related {
    margin-top: var(--space-xl);
    font-size: 0.875rem;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm) var(--space-md);
    align-items: center;
  }

  .seo-related a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .seo-related a:hover {
    color: var(--color-text);
  }
</style>
