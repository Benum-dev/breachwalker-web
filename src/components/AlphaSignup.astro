---
import { COPY } from "../data/copy";
import { SITE } from "../data/site";

const tallyUrl = SITE.tallyFormUrl;
---

<div class="alpha-signup">
  {
    tallyUrl ? (
      <>
        <iframe
          class="tally-frame"
          data-tally-src={tallyUrl}
          title="Alpha signup form"
          loading="lazy"
          width="100%"
          height="500"
        />
        <script is:inline async src="https://tally.so/widgets/embed.js"></script>
      </>
    ) : (
      <div class="alpha-fallback">
        <h2>{COPY.alpha.fallbackTitle}</h2>
        <p class="muted">{COPY.alpha.fallbackBody}</p>
        <p>
          <a href={`mailto:${SITE.contactEmail}?subject=Alpha%20access`}>
            {SITE.contactEmail}
          </a>
        </p>
      </div>
    )
  }
</div>

<script>
  document.querySelectorAll('[data-analytics="cta-alpha"]').forEach((el) => {
    el.addEventListener("click", () => {
      window.dispatchEvent(new CustomEvent("bw:analytics", { detail: "cta_click_alpha" }));
    });
  });
</script>
