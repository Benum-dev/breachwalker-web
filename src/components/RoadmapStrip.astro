---
import { pagePath } from "../data/site";
---

<section class="roadmap-strip">
  <div class="container roadmap-strip__inner">
    <div>
      <p class="eyebrow">Roadmap</p>
      <h2>Alpha now. Item NFTs on Base later.</h2>
      <p class="muted">
        Closed alpha is off-chain — no wallet. Planned: marketplace settlement in
        Strikes, utility-first item NFTs via asset bridge on Base, Coinbase Wallet
        onboarding, and sponsored minting we are exploring for first-time bridge-out.
      </p>
    </div>
    <div class="roadmap-strip__actions">
      <a class="btn btn--ghost" href={pagePath("/item-economy")}>Item economy</a>
      <a class="btn btn--ghost" href={pagePath("/faq") + "#faq-nfts"}>NFT FAQ</a>
    </div>
  </div>
</section>

<style>
  .roadmap-strip {
    padding: var(--space-2xl) 0;
    background: var(--color-bg-elevated);
    border-top: 1px solid var(--color-border-subtle);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .roadmap-strip__inner {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xl);
    justify-content: space-between;
    align-items: flex-end;
  }

  .roadmap-strip h2 {
    font-size: 1.25rem;
    margin-bottom: var(--space-sm);
  }

  .roadmap-strip__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }
</style>
