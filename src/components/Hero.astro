---
import { COPY } from "../data/copy";
---

<section class="hero">
  <div class="hero__glow" aria-hidden="true"></div>
  <div class="container hero__inner">
    <p class="eyebrow">{COPY.hero.eyebrow}</p>
    <h1>{COPY.hero.title}</h1>
    <p class="hero__subhead muted">{COPY.hero.subhead}</p>
    <div class="hero__actions">
      <a class="btn btn--primary" href="/alpha" data-analytics="cta-alpha">
        {COPY.hero.ctaPrimary}
      </a>
      <a class="btn btn--ghost" href="/faq">
        {COPY.hero.ctaSecondary}
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: var(--space-4xl) 0 var(--space-3xl);
    overflow: hidden;
  }

  .hero__glow {
    position: absolute;
    inset: -40% -20% auto;
    height: 70%;
    background: radial-gradient(
      ellipse at 50% 0%,
      rgba(212, 162, 74, 0.14) 0%,
      transparent 65%
    );
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    max-width: 40rem;
  }

  .hero__subhead {
    font-size: 1.125rem;
    line-height: 1.65;
    margin-bottom: var(--space-xl);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }
</style>
