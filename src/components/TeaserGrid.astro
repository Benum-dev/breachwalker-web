---
import { COPY } from "../data/copy";
---

<section class="teasers" aria-labelledby="teasers-heading">
  <div class="container">
    <h2 id="teasers-heading" class="visually-hidden">What to expect</h2>
    <div class="teasers__grid">
      {
        COPY.teasers.map((teaser) => (
          <article class="teaser-card">
            <p class="teaser-card__label">{teaser.label}</p>
            <h3>{teaser.title}</h3>
            <p class="muted">{teaser.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<section class="lore-whispers" aria-label="Lore whispers">
  <div class="container lore-whispers__inner">
    <p class="eyebrow">Whispers from the breach</p>
    <ul class="lore-whispers__list">
      {
        COPY.loreWhispers.map((whisper) => (
          <li><em>{whisper}</em></li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .teasers {
    padding: var(--space-3xl) 0;
    border-top: 1px solid var(--color-border-subtle);
  }

  .teasers__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: var(--space-lg);
  }

  .teaser-card {
    padding: var(--space-xl);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    background: var(--color-bg-elevated);
    box-shadow: var(--shadow-card);
  }

  .teaser-card__label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 var(--space-sm);
  }

  .lore-whispers {
    padding: var(--space-2xl) 0 var(--space-3xl);
  }

  .lore-whispers__inner {
    padding: var(--space-xl);
    border-radius: var(--radius-md);
    background: linear-gradient(
      135deg,
      var(--color-accent-dim) 0%,
      transparent 60%
    );
    border: 1px solid var(--color-border-subtle);
  }

  .lore-whispers__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .lore-whispers__list li {
    font-family: var(--font-display);
    font-size: 1.125rem;
    color: var(--color-text-muted);
  }
</style>
